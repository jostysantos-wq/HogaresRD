# Gmail credentials for sending notification emails
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# 2. Create an App Password for "Mail"
# 3. Paste it below (no spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Admin panel password — change this to something secure
ADMIN_KEY=hogaresrd-admin-2026

# ── Stripe (payment processing) ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get webhook secret after running: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Or from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these products/prices in Stripe Dashboard, then paste the Price IDs here
# Broker plan: $10/month
STRIPE_BROKER_PRICE_ID=price_...
# Inmobiliaria plan: $25/month
STRIPE_INM_PRICE_ID=price_...

# Full URL of your site (used for Stripe redirect URLs)
BASE_URL=https://hogaresrd.com
