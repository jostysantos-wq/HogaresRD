# ──────────────────────────────────────────────────────────────────────────
# HogaresRD — environment variables
#
# Copy this file to `.env` and fill in real values. Server validates the
# REQUIRED block at boot and refuses to start if any are missing
# (see server.js → checkEnv()). OPTIONAL blocks degrade gracefully but
# disable specific features.
# ──────────────────────────────────────────────────────────────────────────

# ── REQUIRED — server refuses to boot without these ───────────────────────
# Random hex string ≥32 chars. Sign + verify all user JWTs.
JWT_SECRET=replace-with-32+-random-hex-chars

# Random string. Required to access the /admin panel via x-admin-key header.
ADMIN_KEY=hogaresrd-admin-CHANGE-ME

# REQUIRED in NODE_ENV=production. Random hex ≥32 chars. Used for AES-256-GCM
# field-level encryption of cedulas, monthly_income, employer_name, and
# co-applicant PII. **Critical**: rotating JWT_SECRET without ENCRYPTION_KEY
# set will orphan all encrypted data — set this once and never rotate it
# casually. Falls back to JWT_SECRET in dev/test only.
ENCRYPTION_KEY=replace-with-32+-random-hex-chars

# ── JWT ROTATION (optional but recommended for ops) ───────────────────────
# 14-day grace window for rotating JWT_SECRET. To rotate:
#   1. Copy current JWT_SECRET to JWT_SECRET_PREV
#   2. Set JWT_SECRET to a new value
#   3. Wait 14 days for all sessions to refresh
#   4. Remove JWT_SECRET_PREV
JWT_SECRET_PREV=

# ── DATABASE ──────────────────────────────────────────────────────────────
# Postgres connection string for production. Empty/unset → SQLite local mode.
# Format: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional: path to CA cert PEM if your Postgres requires custom TLS.
DB_CA_CERT=

# ── STRIPE (payments) ─────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret. Without it /api/stripe/webhook returns 503.
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` for dev.
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring price IDs (create products in Stripe Dashboard, paste IDs here)
STRIPE_BROKER_PRICE_ID=price_...   # Broker plan: $10/month
STRIPE_INM_PRICE_ID=price_...      # Inmobiliaria + Constructora: $25/month

# ── EMAIL ─────────────────────────────────────────────────────────────────
# Transport priority: Gmail API → Resend HTTP → Workspace SMTP.
# Set ONE of the three blocks; mailer.js auto-detects.

# (1) Gmail API via Google Workspace service account (no SMTP needed)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DELEGATED_USER=

# (2) Resend (HTTPS API, easiest for new deployments)
RESEND_API_KEY=re_...

# (3) Legacy Gmail SMTP App Password (only if SMTP_PRIMARY=1)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Admin notification address (orphaned leads, ad approvals, etc.)
ADMIN_EMAIL=admin@yourdomain.com

# ── ADMIN PANEL ───────────────────────────────────────────────────────────
# URL slug for admin (default: 'admin'). Change to obscure.
ADMIN_PATH=admin
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. Generate via:
#   node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
ADMIN_PASSWORD_HASH=$2b$10$...
# Random hex ≥32 chars. Signs admin session JWTs (separate from user JWT_SECRET).
ADMIN_SESSION_SECRET=replace-with-32+-random-hex-chars
# Optional: previous admin secret for rotation grace.
ADMIN_SESSION_SECRET_PREV=
# Optional TOTP secret for admin 2FA (base32, e.g. from `otpauth://...`)
ADMIN_TOTP_SECRET=

# ── PUSH NOTIFICATIONS ────────────────────────────────────────────────────
# VAPID keys for web-push. Auto-generated and persisted to data/ if unset.
# Generate manually: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Apple Push Notification Service for iOS app
APNS_KEY_PATH=/path/to/AuthKey_XXXXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.josty.hogaresrd
APNS_PRODUCTION=false

# ── TWILIO (SMS / WhatsApp 2FA) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155551234

# ── APPLE SIGN-IN / IAP ───────────────────────────────────────────────────
# Bundle ID matching the iOS app. Used to validate JWS receipts.
APPLE_BUNDLE_ID=com.josty.hogaresrd

# ── META (Facebook) WEBHOOK + CAPI ────────────────────────────────────────
# Lead-ad webhook signature verification. Without it /api/webhooks/meta 503s.
META_APP_SECRET=
# Verify-token used during the Meta app's webhook handshake.
META_VERIFY_TOKEN=
# Server-side Conversions API access token + pixel id
META_ACCESS_TOKEN=
META_PIXEL_ID=
# Meta App credentials for OAuth flow
FB_APP_ID=
FB_APP_SECRET=

# ── OBJECT STORAGE (DigitalOcean Spaces / S3-compatible) ──────────────────
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=nyc3
SPACES_BUCKET=
SPACES_CDN_URL=

# ── AI FEATURES ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ENABLE_AI_MONITOR=false

# ── CASCADE ENGINE ────────────────────────────────────────────────────────
ENABLE_CASCADE=true
# Force the cascade to behave as if the market is open (ignore weekend/night
# rules). Use only for staging/load tests.
CASCADE_FORCE_MARKET_OPEN=false

# ── OPS / OBSERVABILITY ───────────────────────────────────────────────────
# Webhook URL (Slack/Discord/PagerDuty inbound) for crash-loop + uncaught
# exception alerts. utils/alerts.js POSTs JSON here. Empty → console.warn only.
ALERT_WEBHOOK_URL=

# Comma-separated CORS allowlist. Empty → reflect Origin.
ALLOWED_ORIGINS=

# Set to 'true' to make CSP report-only (logging mode, no enforcement).
CSP_REPORT_ONLY=false

# ── RUNTIME ───────────────────────────────────────────────────────────────
# Full URL of your site (used for Stripe redirect URLs and email links).
BASE_URL=https://hogaresrd.com
NODE_ENV=production
PORT=3000
